# ── HIRF Platform environment ─────────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project (Settings → API). When left empty the app runs in
# demo mode with the bundled seed data — useful for previews.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for Edge/Admin operations (never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for auth redirects & emails)
NEXT_PUBLIC_SITE_URL=https://app.hirf.sa
